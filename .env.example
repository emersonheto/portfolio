# Database PostgreSQL (separate service in Dokploy)
DATABASE_URI="postgresql://user:password@host:5432/portfolio_db"

# Payload CMS Secret (minimum 32 characters)
PAYLOAD_SECRET="your-super-secret-key-minimum-32-characters-long"

# Next.js Public Variables
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"
NEXT_PUBLIC_SITE_NAME="Your Name Portfolio"

# Cloudinary for media uploads
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
